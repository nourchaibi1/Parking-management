  label30 = gtk_label_new_with_mnemonic (_("retour"));
  gtk_widget_show (label30);
  gtk_box_pack_start (GTK_BOX (hbox13), label30, FALSE, FALSE, 0);

  button_affrech = gtk_button_new ();
  gtk_widget_show (button_affrech);
  gtk_fixed_put (GTK_FIXED (fixed4), button_affrech, 264, 80);
  gtk_widget_set_size_request (button_affrech, 160, 40);

  alignment12 = gtk_alignment_new (0.5, 0.5, 0, 0);
  gtk_widget_show (alignment12);
  gtk_container_add (GTK_CONTAINER (button_affrech), alignment12);

  hbox12 = gtk_hbox_new (FALSE, 2);
  gtk_widget_show (hbox12);
  gtk_container_add (GTK_CONTAINER (alignment12), hbox12);

  image12 = gtk_image_new_from_stock ("gtk-find", GTK_ICON_SIZE_BUTTON);
  gtk_widget_show (image12);
  gtk_box_pack_start (GTK_BOX (hbox12), image12, FALSE, FALSE, 0);

  label29 = gtk_label_new_with_mnemonic (_("<span foreground=\"purple\" ><b>Rechercher</b></span>"));
  gtk_widget_show (label29);
  gtk_box_pack_start (GTK_BOX (hbox12), label29, FALSE, FALSE, 0);
  gtk_label_set_use_markup (GTK_LABEL (label29), TRUE);

  label32 = gtk_label_new ("");
  gtk_widget_show (label32);
  gtk_fixed_put (GTK_FIXED (fixed4), label32, 440, 80);
  gtk_widget_set_size_request (label32, 160, 48);

  g_signal_connect ((gpointer) treeview_affrech, "row_activated",
                    G_CALLBACK (on_treeview_affrech_row_activated),
                    NULL);
  g_signal_connect ((gpointer) button_Retrech, "clicked",
                    G_CALLBACK (on_button_Retrech_clicked),
                    NULL);
  g_signal_connect ((gpointer) button_affrech, "clicked",
                    G_CALLBACK (on_button_affrech_clicked),
                    NULL);

  /* Store pointers to all widgets, for use by lookup_widget(). */
  GLADE_HOOKUP_OBJECT_NO_REF (window_rech, window_rech, "window_rech");
  GLADE_HOOKUP_OBJECT (window_rech, fixed4, "fixed4");
  GLADE_HOOKUP_OBJECT (window_rech, treeview_affrech, "treeview_affrech");
  GLADE_HOOKUP_OBJECT (window_rech, entry_rechaff, "entry_rechaff");
  GLADE_HOOKUP_OBJECT (window_rech, label28, "label28");
  GLADE_HOOKUP_OBJECT (window_rech, button_Retrech, "button_Retrech");
  GLADE_HOOKUP_OBJECT (window_rech, alignment13, "alignment13");
  GLADE_HOOKUP_OBJECT (window_rech, hbox13, "hbox13");
  GLADE_HOOKUP_OBJECT (window_rech, image13, "image13");
  GLADE_HOOKUP_OBJECT (window_rech, label30, "label30");
  GLADE_HOOKUP_OBJECT (window_rech, button_affrech, "button_affrech");
  GLADE_HOOKUP_OBJECT (window_rech, alignment12, "alignment12");
  GLADE_HOOKUP_OBJECT (window_rech, hbox12, "hbox12");
  GLADE_HOOKUP_OBJECT (window_rech, image12, "image12");
  GLADE_HOOKUP_OBJECT (window_rech, label29, "label29");
  GLADE_HOOKUP_OBJECT (window_rech, label32, "label32");

  return window_rech;
}

